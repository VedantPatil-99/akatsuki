# Application environment (e.g., development, production)
NODE_ENV="development"

# The base URL of your application frontend
NEXT_PUBLIC_SITE_URL="http://localhost:3000"


# ==========================================
# SUPABASE (Database & Auth)
# ==========================================

# Your Supabase project REST URL
NEXT_PUBLIC_SUPABASE_URL="https://abcdefghijklmno.supabase.co"

# Your Supabase public 'anon' key (safe for browser)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY="sb_publishable_....."

# Your Supabase Service Role key (Never expose this to the client/browser!)
SUPABASE_SECRET_KEY="sb_secret_....."


# ==========================================
# MICROSERVICES & INFRASTRUCTURE
# ==========================================

# URL for your custom Python-based document/asset extraction service (append /api/extract at the end)
EXTRACTOR_SERVICE_URL="https://my-python-extractor-service.onrender.com" 

# API key for Browserless.io (headless browser for scraping/PDF generation)
BROWSERLESS_TOKEN="bl_dummy_token_1a2b3c4d5e"

# Commercial license key to remove Tldraw watermarks/enable pro features
NEXT_PUBLIC_TLDRAW_LICENSE_KEY="tldraw_license_dummy_abc_123"


# ==========================================
# AI & MACHINE LEARNING
# ==========================================

# Vercel AI Gateway key for proxying, caching, and rate-limiting LLM calls
AI_GATEWAY_API_KEY="sk-vercel-ai-gateway-dummy-key"

# Cohere API key (used for generating RAG embeddings)
COHERE_API_KEY="dummy_cohere_api_key_abc123"

# LlamaCloud API key (used for LlamaParse document parsing)
LLAMA_CLOUD_API_KEY="llx-dummy_llama_cloud_key_xyz987"

# Google Gemini API key (used for Vision OCR on the whiteboard)
GEMINI_API_KEY="AIzaSy_dummy_gemini_vision_key_456"

# Groq API key (used for blazing fast Llama-3 inference)
GROQ_API_KEY="gsk_dummy_groq_inference_key_789"


# ==========================================
# UPSTASH QSTASH (Background Jobs/Queues)
# ==========================================

# Base URL for publishing QStash messages
QSTASH_URL="https://qstash.upstash.io/v2/publish"

# QStash REST API token for authentication
QSTASH_TOKEN="eyJhbGciOiJIUzI1NiJ9.dummy_qstash_token.xyz"

# Signing key used to verify incoming webhooks from QStash
QSTASH_CURRENT_SIGNING_KEY="sig_dummy_current_key_123abc"

# Fallback signing key used during Upstash key rotation
QSTASH_NEXT_SIGNING_KEY="sig_dummy_next_key_456def"